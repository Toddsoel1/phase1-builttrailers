# Copy to .env for local Postgres, or leave DATABASE_URL unset to use the built-in
# PGlite engine (zero-install, great for trying it on your laptop).

# Production / local Postgres connection string:
# DATABASE_URL=postgresql://user:password@host:5432/builttrailers

# Force the in-process PGlite engine even if DATABASE_URL is set (handy for demos):
# USE_PGLITE=1

# Strong random secret for signing login tokens (Render generates this automatically):
JWT_SECRET=change-me-to-a-long-random-string

# Burdened blended labor rate ($/hr) used in cost rollups until Phase 5 wires real payroll:
LABOR_RATE=37

# Port (Render sets this automatically):
PORT=3000

# ---- Live QuickBooks Online (leave unset to stay in simulated mode) ----
# Setup: create an app at developer.intuit.com, add redirect URI
#   http://localhost:3000/api/auth/qbo/callback   (local)
#   https://your-render-url.onrender.com/api/auth/qbo/callback   (cloud)
# Then set CLIENT_ID + CLIENT_SECRET below, start the server, and visit:
#   http://localhost:3000/api/auth/qbo   (as an admin user)
# The OAuth flow fills in QBO_REFRESH_TOKEN and QBO_REALM_ID automatically.
#
# ACCOUNTING_MODE=quickbooks
# QBO_ENV=production         # sandbox | production
# QBO_CLIENT_ID=
# QBO_CLIENT_SECRET=
# QBO_REFRESH_TOKEN=         # filled in by the /api/auth/qbo flow; auto-rotates via DB
# QBO_REALM_ID=

# ---- Live SMS via Twilio (leave unset to stay in simulated mode) ----
# SMS_MODE=twilio
# TWILIO_SID=
# TWILIO_TOKEN=
# TWILIO_FROM=
